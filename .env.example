# ─── Basecamp OAuth ───────────────────────────────────────────────────────
# Register a personal integration at https://launchpad.37signals.com/integrations
# (no account-admin rights needed — it's tied to your own 37signals login).
BASECAMP_CLIENT_ID=
BASECAMP_CLIENT_SECRET=
# Must match the redirect URI you registered. For the one-time local authorize
# script the default below is fine.
BASECAMP_REDIRECT_URI=http://localhost:8000/oauth/callback
# Basecamp REQUIRES a User-Agent that identifies your app and gives a contact.
BASECAMP_USER_AGENT=BasecampButtler (you@example.com)

# ─── Notifications ────────────────────────────────────────────────────────
# Which channel to use: ntfy (recommended, no account) | telegram | none
NOTIFY_CHANNEL=ntfy

# ntfy: install the ntfy app, subscribe to a hard-to-guess topic, put it here.
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=basecamp-butler-change-me-to-something-random
NTFY_TOKEN=
# Public URL of THIS app — makes notification Add/Dismiss/Done buttons work.
# Must be reachable from your phone (same LAN / VPN).
# Behind a full-tunnel corporate VPN the LAN IP stops resolving — use a Tailscale
# IP / MagicDNS name here instead (e.g. http://nas:8000). See README "Remote
# access over a corporate VPN".
APP_BASE_URL=http://YOUR-NAS-IP:8000

# Telegram (only if NOTIFY_CHANNEL=telegram): bot via @BotFather, chat id from
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Polling / behaviour ──────────────────────────────────────────────────
# How often to check Basecamp for new activity, in minutes.
POLL_INTERVAL_MINUTES=5
# Consider a to-do "due soon" (→ reminder) within this many days.
DUE_SOON_DAYS=3
# Extra sources beyond to-dos/messages/comments. Keep values on their own line
# with NO trailing inline comment — a mangled bool (e.g. "true # note") makes the
# app fail to start.
# Project group chat:
POLL_CAMPFIRE=true
# 1:1 / small-group direct messages (Pings):
POLL_PINGS=true

# ─── Database (compose sets DATABASE_URL for you; override for local runs) ──
POSTGRES_USER=basecamp
POSTGRES_PASSWORD=basecamp
POSTGRES_DB=basecamp
# DATABASE_URL=postgresql+psycopg2://basecamp:basecamp@localhost:5432/basecamp

# ─── Web ──────────────────────────────────────────────────────────────────
WEB_PORT=8000
# Optional shared secret to lock down the web UI + API. Leave blank for an open,
# LAN-only setup. If set, browsers get an HTTP Basic prompt (any username, this
# value as the password) and the ntfy action buttons send it automatically.
# Strongly recommended if the app is reachable beyond your trusted LAN.
WEB_AUTH_TOKEN=

# ─── Optional: LLM classifier (v2, off by default) ────────────────────────
# Options: rules | ollama
CLASSIFIER=rules
# Point this at wherever Ollama runs. To use Ollama on another machine (e.g. a
# GPU desktop), set OLLAMA_URL to that host and, on that machine, start Ollama
# with OLLAMA_HOST=0.0.0.0 so it accepts LAN connections (and open port 11434).
#   e.g. OLLAMA_URL=http://YOUR-OLLAMA-HOST:11434
# If Ollama runs on a machine that joins a full-tunnel corporate VPN (which hides
# it from the NAS), point OLLAMA_URL at that machine's Tailscale IP instead, and
# firewall port 11434 to the tailnet range 100.64.0.0/10. See README "Remote
# access over a corporate VPN".
OLLAMA_URL=http://YOUR-OLLAMA-HOST:11434
OLLAMA_MODEL=llama3.1:8b

# ─── Optional: reach Ollama over Tailscale when the host can't route to it ──
# Needed when Ollama lives on another Tailscale node and the Docker host cannot
# reach the tailnet itself (e.g. a Synology without /dev/net/tun, where the
# Tailscale package runs in userspace mode, so containers have no tailnet route).
# The bundled `tailscale` sidecar (see docker-compose.yml) does this. It is inert
# until you give it an auth key, so just set the vars below and redeploy:
#   1. Generate a Tailscale auth key: admin console → Settings → Keys.
#   2. Set TS_AUTHKEY + OLLAMA_PROXY below, and OLLAMA_URL to the Ollama node's
#      tailnet IP.
#   3. Redeploy. The app reaches Ollama via the sidecar's HTTP proxy.
# TS_AUTHKEY=tskey-auth-xxxxxxxx
# Route ONLY Ollama traffic through the sidecar (Basecamp + DB are unaffected):
# OLLAMA_PROXY=http://tailscale:1055
# Optional: the name this node shows up as in your tailnet, and extra tailscaled
# flags (e.g. --accept-routes).
# TS_HOSTNAME=basecamp-butler
# TS_EXTRA_ARGS=
