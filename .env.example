# ─── Basecamp OAuth ───────────────────────────────────────────────────────
# Register a personal integration at https://launchpad.37signals.com/integrations
# (no account-admin rights needed — it's tied to your own 37signals login).
BASECAMP_CLIENT_ID=
BASECAMP_CLIENT_SECRET=
# Must match the redirect URI you registered. For the one-time local authorize
# script the default below is fine.
BASECAMP_REDIRECT_URI=http://localhost:8000/oauth/callback
# Basecamp REQUIRES a User-Agent that identifies your app and gives a contact.
BASECAMP_USER_AGENT=BasecampButtler (you@example.com)

# ─── Notifications ────────────────────────────────────────────────────────
# Which channel to use: ntfy (recommended, no account) | telegram | none
NOTIFY_CHANNEL=ntfy

# ntfy: install the ntfy app, subscribe to a hard-to-guess topic, put it here.
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=basecamp-butler-change-me-to-something-random
NTFY_TOKEN=
# Public URL of THIS app — makes notification Add/Dismiss/Done buttons work.
# Must be reachable from your phone (same LAN / VPN).
APP_BASE_URL=http://YOUR-NAS-IP:8000

# Telegram (only if NOTIFY_CHANNEL=telegram): bot via @BotFather, chat id from
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Polling / behaviour ──────────────────────────────────────────────────
POLL_INTERVAL_MINUTES=7
# Consider a to-do "due soon" (→ reminder) within this many days.
DUE_SOON_DAYS=3

# ─── Database (compose sets DATABASE_URL for you; override for local runs) ──
POSTGRES_USER=basecamp
POSTGRES_PASSWORD=basecamp
POSTGRES_DB=basecamp
# DATABASE_URL=postgresql+psycopg2://basecamp:basecamp@localhost:5432/basecamp

# ─── Web ──────────────────────────────────────────────────────────────────
WEB_PORT=8000

# ─── Optional: local LLM classifier (v2, off by default) ──────────────────
CLASSIFIER=rules            # rules | ollama
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
